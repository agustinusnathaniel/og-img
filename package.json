{
  "name": "nextarter-chakra",
  "version": "1.1.2",
  "private": true,
  "author": "agustinusnathaniel",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "next build",
    "turbo": "pnpm dlx turbo@2.8.19",
    "build:turbo": "pnpm turbo build",
    "start": "next start",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "type:check": "tsc --noEmit",
    "check:turbo": "pnpm turbo ultracite:check type:check",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource/outfit": "^5.2.8",
    "clsx": "^2.1.1",
    "lodash-es": "^4.17.23",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "commit-and-tag-version": "^12.7.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14"
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
